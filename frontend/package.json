{
  "name": "bim-rag-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local desktop BIM viewer + conversational frontend for the BIM_RAG query backend (spec_v006).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gen:api": "openapi-typescript ../frontend_openapi_snapshot.json -o src/types/api.ts --default-non-nullable=false",
    "prepare:model": "tsx scripts/prepare-viewer-model.ts"
  },
  "dependencies": {
    "@thatopen/components": "~3.4.6",
    "@thatopen/fragments": "~3.4.6",
    "dompurify": "^3.1.7",
    "idb": "^8.0.0",
    "marked": "^14.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "~0.185.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/ibm-plex-sans": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "~0.185.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.7",
    "web-ifc": "0.0.77"
  }
}
